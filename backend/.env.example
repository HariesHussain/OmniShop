# Backend server
NODE_ENV=production
PORT=5000

# Allowed frontend origins (comma-separated)
# Example: https://your-app.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=https://your-frontend.vercel.app
CLIENT_URL=https://your-frontend.vercel.app

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_key_here

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@your-domain.com
ORDER_ALERT_ADMIN_EMAIL=admin@your-domain.com

# Firebase Admin SDK (backend only)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# OTP hardening (optional but recommended)
OTP_HASH_SECRET=replace_with_random_secret

# Delivery scheduler (optional overrides)
DELIVERY_START_OFFSET_DAYS=7
MAX_DELIVERIES_PER_DAY=10
MAX_DELIVERY_SEARCH_DAYS=30
